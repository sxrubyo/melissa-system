    "melissa_send_guard.py",
    "melissa_nuke_robot_phrases.py",
    "melissa_pitch_upgrade.py",
    "smart_handoff.py",
    "melissa_pairing.py",
    "knowledge_base.py",
    "search.py",
    "brand_assets.py",
    "nova_bridge.py",
    "ecosystem.config.js",
    "run.sh",
    "requirements.txt",
    ".env.example",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "install.sh",
    "package.json",
    "melissa_admin.py",
    "melissa_admin_api.py",
    "melissa_config.py",
    "melissa_demo.py",
    "melissa_production.py",
    "melissa_router.py",
